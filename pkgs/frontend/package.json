{
  "name": "frontend",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:base": "dotenv -e .env.base react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json}\"",
    "codegen": "graphql-codegen --config codegen.ts",
    "test:e2e:dev": "cypress open"
  },
  "dependencies": {
    "@0xsplits/splits-sdk": "^4.1.0",
    "@apollo/client": "^3.12.4",
    "@chakra-ui/react": "^3.28.0",
    "@emotion/cache": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@hatsprotocol/sdk-v1-core": "^0.10.0",
    "@hatsprotocol/sdk-v1-subgraph": "^1.0.0",
    "@privy-io/react-auth": ">=2.4.2 <=2.5.0",
    "@react-router/node": "^7.9.4",
    "@react-router/serve": "^7.9.5",
    "@remix-run/react": "^2.17.2",
    "@solana/web3.js": "^1.95.5",
    "@tanstack/react-query": "^5.68.0",
    "@zxing/library": "^0.21.3",
    "axios": "^1.7.9",
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^3.1.0",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.5.0",
    "graphql": "^16.10.0",
    "isbot": "^5.1.11",
    "namestone-sdk": "^0.2.11",
    "next-themes": "^0.4.3",
    "permissionless": "^0.2.35",
    "pinata": "^2.5.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.54.2",
    "react-icons": "^5.4.0",
    "react-router": "^7.9.5",
    "react-router-dom": "^7.9.5",
    "react-toastify": "^11.0.3",
    "remix-toast": "1.2.2",
    "stream": "^0.0.3",
    "swiper": "^11.2.6",
    "viem": "^2.21.51"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.3",
    "@graphql-codegen/client-preset": "4.5.1",
    "@graphql-codegen/introspection": "4.0.3",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@internationalized/date": "^3.10.0",
    "@internationalized/number": "^3.6.5",
    "@react-router/dev": "^7.9.3",
    "@react-router/fs-routes": "^7.9.4",
    "@synthetixio/synpress": "^4.0.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "autoprefixer": "^10.4.19",
    "cypress": "^14.2.0",
    "cypress-file-upload": "^5.0.8",
