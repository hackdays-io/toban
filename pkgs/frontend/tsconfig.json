{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx",
    ".react-router/types/**/*",
    "app/entry.client.tsx",
    "app/entry.server.tsx"
  ],
  "exclude": [
    "**/@internationalized+date/**",
    "**/@internationalized+number/**",
    "**/@internationalized/**",
    "node_modules/",
    "**/node_modules/**",
    "gql",
    "**/.react-router",
    "**/.react-router/**",
    "**/types/+routes.ts"
  ],
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": [
      "@react-router/node",
      "@react-router/fs-routes",
      "vite/client",
      "cypress",
      "cypress-file-upload"
    ],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "rootDirs": [".", "./.react-router/types"],
    // Vite takes care of building everything, not tsc.
    "noEmit": true
  }
}
